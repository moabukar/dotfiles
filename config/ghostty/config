# Ghostty config (read by cmux). Reload via `cmux reload-config` or cmd+shift+,

font-family = MesloLGS NF
font-size = 13
adjust-cell-height = 10%
window-padding-x = 10
window-padding-y = 8
window-padding-balance = true
mouse-hide-while-typing = true
scrollback-limit = 100000
audible-bell = false
cursor-style-blink = false
bold-is-bright = false

background = 0A1628
foreground = E2E8F0

cursor-color = 60A5FA
cursor-style = block

selection-background = 1E40AF
selection-foreground = FFFFFF

# Blue-leaning ANSI palette. Reds stay vivid so Claude Code diff `-` lines and
# errors still pop; greens lean teal, yellows lean warm gold to balance the navy.
palette = 0=#0F1F3D
palette = 1=#EF4444
palette = 2=#34D399
palette = 3=#FBBF24
palette = 4=#60A5FA
palette = 5=#C084FC
palette = 6=#22D3EE
palette = 7=#E2E8F0
palette = 8=#334155
palette = 9=#F87171
palette = 10=#6EE7B7
palette = 11=#FCD34D
palette = 12=#93C5FD
palette = 13=#D8B4FE
palette = 14=#67E8F9
palette = 15=#F8FAFC
