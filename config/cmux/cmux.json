  // ---- Active settings below ----
  // Reload with cmd+shift+, after editing.

  "app": {
    "appearance": "dark",
    "appIcon": "dark"
  },

  "workspaceColors": {
    "indicatorStyle": "blueWashColorRail",
    "selectionColor": "#1D4ED8",
    "notificationBadgeColor": "#3B82F6",
    "colors": {
      "FP":      "#0EA5A4",
      "AMD":     "#ED1C24",
      "coderco": "#F59E0B",
      "Content": "#A855F7",
      "general": "#64748B"
    }
  },

  "sidebarAppearance": {
    "matchTerminalBackground": false,
    "tintColor": "#1E3A8A",
    "darkModeTintColor": "#1E3A8A",
    "lightModeTintColor": "#3B82F6",
    "tintOpacity": 0.28
  },

  "notifications": {
    "sound": "Tink",
    "paneFlash": true,
    "unreadPaneRing": true,
    "dockBadge": true,
    "showInMenuBar": true
  },

  "sidebar": {
    "branchLayout": "horizontal",
    "showPullRequests": true,
    "makePullRequestsClickable": true,
    "openPullRequestLinksInCmuxBrowser": true,
    "showPorts": true,
    "openPortLinksInCmuxBrowser": true,
    "showProgress": true,
    "showNotificationMessage": true,
    "showBranchDirectory": true,
    "showCustomMetadata": true,
    "showWorkspaceDescription": true,
    "showSSH": false,
    "showLog": false,
    "watchGitStatus": true,
    "hideAllDetails": false
  },

  "browser": {
    "theme": "dark",
    "defaultSearchEngine": "google",
    "showSearchSuggestions": true,
    "showImportHintOnBlankTabs": false,
    "openTerminalLinksInCmuxBrowser": true,
    "interceptTerminalOpenCommandInCmuxBrowser": true,
    "discardHiddenWebViews": true,
    "hiddenWebViewDiscardDelaySeconds": 300
  }
}
